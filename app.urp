# App and database configuration
database dbname=expense_db
sql schema/schema.sql
# Static assets and allowed URLs
file /base.css src/static/base.css
file /dashboard.css src/static/dashboard.css
allow url /base.css
allow url /dashboard.css
allow url /Main/home
allow url /Main/dashboard

# Module load order (top to bottom)
schema/tables
src/expense
src/frontend/layout
src/frontend/home
src/frontend/dashboard
src/main
